[% INCLUDE 'doc-head-open.inc' %]
 <title>Koha: Patron Emailer: Configuration</title>
[% INCLUDE 'doc-head-close.inc' %]

<style>
.logo-supporter {
  padding: 10px;
}
</style>
</head>
<body>
[% INCLUDE 'header.inc' %]
[% INCLUDE 'cat-search.inc' %]

<nav id="breadcrumbs" aria-label="Breadcrumb" class="breadcrumb">
    <ol>
        <li>
            <a href="/cgi-bin/koha/mainpage.pl">Home</a>
        </li>
        <li>
            <a href="/cgi-bin/koha/plugins/plugins-home.pl">Plugins</a>
        </li>
        <li>
            Patron Emailer
        </li>
        <li>
            Configuration
        </li>
    </ol>
</nav>

<div class="main container-fluid" id="doc3">
    <!-- We can access our own plugins resource files using the PLUGIN_PATH variable. -->
    <a href="https://bywatersolutions.com/"><img src="[% PLUGIN_PATH %]/webassets/logo-ByWater.png" class="logo-supporter"/></a>
    <a href="https://www.kansalliskirjasto.fi"><img src="[% PLUGIN_PATH %]/webassets/National_Library_of_Finland_logo.png" class="logo-supporter"/></a>
    <a href="https://www.hypernova.fi/"><img src="[% PLUGIN_PATH %]/webassets/logo-Hypernova.png" class="logo-supporter"/></a>

    <fieldset id="configs">
        <legend>Koha: Patron Emailer: Configuration</legend>

        <!-- Notice our form here has no 'action', this is good, it means that our forms will always get passed back to 'plugins/run.pl'. You could hard code it instead if you prefer -->
        <form method="get">
            [% IF koha_version >= '24.05'; INCLUDE 'csrf-token.inc'; END %]
            <!-- Always pass these two parameters so the plugin system knows what to execute! -->
            <input type="hidden" name="class" value="[% CLASS | html %]"/>
            <input type="hidden" name="method" value="[% METHOD | html %]"/>

            [% IF error %]<div class="warn alert error">Error: [% error | html %]</div>[% END %]

            <p>
                <label for="is_html">HTML message: </label>
                [% IF (is_html) %]
                    <input name="is_html" type="checkbox" value="1" checked="checked"/>
                [% ELSE %]
                    <input name="is_html" type="checkbox" value="1" />
                [% END %]

            </p>


            <p>
                <label for="subject">Email subject: </label>
                <input name="subject" type="text" class="input-xxlarge" size="100" value="[% subject | html %]" />
            </p>

            <p>
                <label for="body">Email text: </label>
                <br/>
                <textarea rows="15" cols="200" name="body">[% body | html %]</textarea>
            </p>

            <p>
                <label for="delimiter">Data delimiter: </label>
                <br/>
                <input name="delimiter" type="text" value="[% delimiter | html %]"/>
            </p>

            <p>This plugin uses Template Toolkit syntax. All the fields in the uploaded CSV file will be available.</p>

            <p>Example:</p>
            <pre>
[% TAGS [- -] %]
First name: [% firstname %]
Last name: [% lastname %]
[- TAGS [% %] -]
            </pre>


            <p>
            <h3 id="delete_scheduled">Delete scheduled notices</h3>
            <table>
            <thead>
            <tr>
            <th>ID</th>
            <th>Report name</th>
            <th>Letter code</th>
            <th>Scheduled on</th>
            <th>Delete</th>
            </tr>
            </thead>
            <tbody>
            [% FOREACH sr_key IN scheduled_notices.keys %]
            <tr>
            <td><label for="delete_[% scheduled_notices.$sr_key.id | html %]">[% scheduled_notices.$sr_key.id | html %]</label></td>
            <td>[% scheduled_notices.$sr_key.report_name %]</td>
            <td>[% scheduled_notices.$sr_key.letter_code %]</td>
            <td>[% scheduled_notices.$sr_key.scheduled_on %]</td>
            <td><input type="checkbox" name="delete_[% scheduled_notices.$sr_key.id | html %]" id="delete_[% scheduled_notices.$sr_key.id | html %]" /></td>
            </tr>
            [% END %]
            </tbody>
            </table>
            </p>
            <input type="hidden" name="save" value="1" />

            <input type="submit" value="Save configuration" />
        </form>
    </fieldset>

[% INCLUDE 'intranet-bottom.inc' %]
